<% title = 'Dashboard'; activeMenu = '/dashboard'; %>

<div class="row g-3">
  <div class="col-12">
    <div class="d-flex align-items-center gap-2 mb-1">
      <i class="bi bi-house-door-fill text-primary fs-4"></i>
      <h5 class="mb-0 fw-bold">Bem-vindo, <%= user.nome.split(' ')[0] %>!</h5>
    </div>
    <p class="text-muted small mb-0">Selecione uma opcao para comecar.</p>
  </div>

  <% menus.filter(function(m){ return m.link !== '/dashboard'; }).forEach(function(m) { %>
  <div class="col-6 col-md-4 col-lg-3">
    <a href="<%= m.link %>" class="text-decoration-none">
      <div class="card h-100 border-0 shadow-sm dash-card text-center p-3 p-md-4">
        <i class="bi <%= m.icone %> dash-icon text-primary mb-2"></i>
        <div class="fw-semibold small"><%= m.descricao %></div>
      </div>
    </a>
  </div>
  <% }); %>
</div>
