<% title = 'Lista do Dia'; activeMenu = '/produtos/lista'; %>

<% if (!cliente) { %>
  <div class="alert alert-warning">Nenhum cliente disponível.</div>
<% } else { %>

<input type="hidden" id="hidCliente" value="<%= cliente.id_cliente %>">

<!-- Cabeçalho compacto -->
<div class="d-flex align-items-center justify-content-between mb-2 gap-2 flex-wrap">
  <div class="d-flex align-items-center gap-1 flex-wrap">
    <i class="bi bi-list-check text-primary fs-5"></i>
    <h6 class="mb-0 fw-bold">Lista do Dia</h6>
    <span class="badge bg-primary bg-opacity-10 text-primary py-1 px-2">
      <i class="bi bi-person me-1"></i><%= cliente.nome %>
    </span>
    <% if (!clienteUnico) { %>
    <a href="/produtos/selecionar?destino=lista" class="btn btn-outline-secondary btn-sm py-0 px-2"
       title="Trocar cliente">
      <i class="bi bi-arrow-left-right"></i>
    </a>
    <% } %>
    <span class="badge bg-secondary bg-opacity-10 text-dark py-1 px-2">
      <i class="bi bi-calendar me-1"></i><%= dtColeta.split('-').reverse().join('/') %>
    </span>
    <a href="/produtos/selecionar-data?id_cliente=<%= cliente.id_cliente %>"
       class="btn btn-outline-secondary btn-sm py-0 px-2" title="Trocar data">
      <i class="bi bi-arrow-left-right"></i>
    </a>
  </div>
  <button class="btn btn-outline-primary btn-sm" id="btnCameraLista" title="Escanear para buscar produto">
    <i class="bi bi-camera-fill"></i>
  </button>
</div>

<!-- Reader câmera (lista) -->
<div id="readerContainerLista" class="d-none mb-2">
  <div class="card border-0 shadow-sm">
    <div class="card-body p-2">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="small text-muted">Aponte para o código de barras do produto</span>
        <button class="btn btn-sm btn-outline-danger" id="btnFecharCameraLista">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      <div id="readerLista" class="rounded overflow-hidden"></div>
    </div>
  </div>
</div>

<!-- Contador -->
<div class="d-flex justify-content-between align-items-center mb-2">
  <span class="small text-muted"><span id="totalProdutos">0</span> produto(s) encontrado(s)</span>
</div>

<!-- Lista de cards -->
<div id="listaProdutos" class="row g-2">
  <% if (produtos.length === 0) { %>
  <div class="col-12 text-center text-muted py-5" id="semProdutos">
    <i class="bi bi-inbox fs-1 opacity-25 d-block mb-2"></i>
    Nenhum produto coletado hoje para este cliente.
  </div>
  <% } %>
  <% produtos.forEach(function(p) { %>
  <%- include('_card_produto', { p }) %>
  <% }); %>
</div>

<!-- Modal de edição -->
<div class="modal fade" id="modalQtd" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2">
        <div>
          <h6 class="modal-title fw-bold mb-0" id="qtdCodigo"></h6>
          <div class="text-muted small" id="qtdDescricao"></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body py-2">
        <div class="mb-2">
          <label class="form-label fw-semibold small">Quantidade coletada <span class="text-muted fw-normal">(opcional)</span></label>
          <input type="text" id="inputQtdModal" class="form-control form-control-lg text-center"
                 pattern="[0-9]*" maxlength="3" placeholder="0">
        </div>
        <div class="d-flex align-items-center justify-content-between">
          <label class="form-label small fw-semibold mb-0">Ao coletado</label>
          <div class="form-check form-switch mb-0">
            <input type="checkbox" id="chkAoColetado" class="form-check-input" role="switch">
          </div>
        </div>
      </div>
      <div class="modal-footer py-2 flex-column gap-1 align-items-stretch">
        <!-- Confirmação de exclusão (oculta por padrão) -->
        <div id="confirmExcluir" class="d-none">
          <div class="text-danger small fw-semibold mb-1">Confirmar exclusão?</div>
          <div class="d-flex gap-1">
            <button type="button" id="btnConfirmarExcluir" class="btn btn-danger btn-sm flex-fill">
              <i class="bi bi-trash me-1"></i>Sim, excluir
            </button>
            <button type="button" id="btnCancelarExcluir" class="btn btn-secondary btn-sm flex-fill">
              Cancelar
            </button>
          </div>
        </div>
        <!-- Rodapé normal -->
        <div class="d-flex gap-1 justify-content-between w-100">
          <button type="button" id="btnExcluirProduto" class="btn btn-outline-danger btn-sm"
                  title="Excluir registro">
            <i class="bi bi-trash"></i>
          </button>
          <div class="d-flex gap-1">
            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" class="btn btn-primary btn-sm" id="btnSalvarQtd">
              <i class="bi bi-floppy me-1"></i>Salvar
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:11">
  <div id="toastLista" class="toast align-items-center text-white border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body small" id="toastListaMsg"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<% } %>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="/js/scanner.js"></script>
<% if (cliente) { %>
<script>
(function() {
  let produtoAtual = null;
  const modalEl  = document.getElementById('modalQtd');
  const modal    = new bootstrap.Modal(modalEl);
  const toastEl  = document.getElementById('toastLista');
  const toast    = new bootstrap.Toast(toastEl, { delay: 2500 });

  function showToast(msg, ok) {
    document.getElementById('toastListaMsg').textContent = msg;
    toastEl.className = 'toast align-items-center text-white border-0 ' + (ok ? 'bg-success' : 'bg-danger');
    toast.show();
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function atualizarTotal() {
    document.getElementById('totalProdutos').textContent =
      document.querySelectorAll('.produto-card').length;
  }
  atualizarTotal();

  // Atualiza visual do card com base em ao_coletado
  function atualizarVisualAoColetado(card, valor) {
    card.style.borderLeft = valor === 'S' ? '3px solid #198754' : '';
    const badge = card.querySelector('.badge-ao-coletado');
    if (badge) badge.style.display = valor === 'S' ? '' : 'none';
  }

  // Click no card: botão editar → abre modal | resto do card → toggle ao_coletado
  document.getElementById('listaProdutos').addEventListener('click', function(e) {
    const btn  = e.target.closest('.btn-editar-qtd');
    const card = e.target.closest('.produto-card');
    if (!card) return;
    if (btn) {
      abrirModalQtd(card);
    } else {
      toggleAoColetado(card);
    }
  });

  function toggleAoColetado(card) {
    fetch('/api/produtos/ao-coletado', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id_cliente:     card.dataset.idCliente,
        codigo_produto: card.dataset.codigo,
        dt_coleta:      card.dataset.dtColeta,
        id_usuario:     card.dataset.idUsuario,
      }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        card.dataset.aoColetado = data.ao_coletado;
        atualizarVisualAoColetado(card, data.ao_coletado);
      } else {
        showToast(data.msg, false);
      }
    })
    .catch(function() { showToast('Erro ao atualizar.', false); });
  }

  function abrirModalQtd(card) {
    produtoAtual = {
      codigo_produto: card.dataset.codigo,
      descricao:      card.dataset.descricao,
      id_cliente:     card.dataset.idCliente,
      dt_coleta:      card.dataset.dtColeta,
      id_usuario:     card.dataset.idUsuario,
      qt_atual:       card.dataset.qt,
      ao_coletado:    card.dataset.aoColetado || 'N',
    };
    document.getElementById('qtdCodigo').textContent    = produtoAtual.codigo_produto;
    document.getElementById('qtdDescricao').textContent = produtoAtual.descricao;
    document.getElementById('inputQtdModal').value      = produtoAtual.qt_atual !== 'null' ? produtoAtual.qt_atual : '';
    document.getElementById('chkAoColetado').checked    = produtoAtual.ao_coletado === 'S';
    document.getElementById('confirmExcluir').classList.add('d-none');
    document.getElementById('btnExcluirProduto').classList.remove('d-none');
    modal.show();
    setTimeout(function() { document.getElementById('inputQtdModal').focus(); }, 400);
  }

  // Salvar quantidade + ao_coletado
  document.getElementById('btnSalvarQtd').addEventListener('click', function() {
    if (!produtoAtual) return;
    const qt = document.getElementById('inputQtdModal').value;
    const ao = document.getElementById('chkAoColetado').checked ? 'S' : 'N';

    fetch('/api/produtos/quantidade', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id_cliente:     produtoAtual.id_cliente,
        codigo_produto: produtoAtual.codigo_produto,
        dt_coleta:      produtoAtual.dt_coleta,
        id_usuario:     produtoAtual.id_usuario,
        qt_coletada:    qt,
        ao_coletado:    ao,
      }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        const cardEl = document.getElementById('card-' + CSS.escape(produtoAtual.codigo_produto));
        if (cardEl) {
          const cardDiv = cardEl.querySelector('.produto-card');
          cardDiv.dataset.qt = qt;
          cardDiv.dataset.aoColetado = ao;
          cardEl.querySelector('.badge.bg-primary').innerHTML =
            '<i class="bi bi-layers me-1"></i>Qtd: ' +
            (qt !== '' ? parseFloat(qt).toLocaleString('pt-BR') : '—');
          atualizarVisualAoColetado(cardDiv, ao);
        }
        showToast('Salvo.', true);
        modal.hide();
      } else {
        showToast(data.msg, false);
      }
    })
    .catch(function() { showToast('Erro de comunicação.', false); });
  });

  // Excluir: mostrar confirmação
  document.getElementById('btnExcluirProduto').addEventListener('click', function() {
    document.getElementById('confirmExcluir').classList.remove('d-none');
    this.classList.add('d-none');
  });

  document.getElementById('btnCancelarExcluir').addEventListener('click', function() {
    document.getElementById('confirmExcluir').classList.add('d-none');
    document.getElementById('btnExcluirProduto').classList.remove('d-none');
  });

  document.getElementById('btnConfirmarExcluir').addEventListener('click', function() {
    if (!produtoAtual) return;

    fetch('/api/produtos', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id_cliente:     produtoAtual.id_cliente,
        codigo_produto: produtoAtual.codigo_produto,
        dt_coleta:      produtoAtual.dt_coleta,
        id_usuario:     produtoAtual.id_usuario,
      }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        const cardEl = document.getElementById('card-' + CSS.escape(produtoAtual.codigo_produto));
        if (cardEl) cardEl.remove();
        atualizarTotal();
        showToast('Registro excluído.', true);
        modal.hide();
      } else {
        showToast(data.msg, false);
      }
    })
    .catch(function() { showToast('Erro ao excluir.', false); });
  });

  initScanner({
    btnAbrir:  'btnCameraLista',
    btnFechar: 'btnFecharCameraLista',
    container: 'readerContainerLista',
    readerId:  'readerLista',
    onDecode: function(codigo) {
      const idCliente = document.getElementById('hidCliente').value;
      if (!idCliente) { showToast('Cliente não selecionado.', false); return; }

      fetch('/api/produtos/buscar?id_cliente=' + idCliente + '&codigo=' + encodeURIComponent(codigo))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.ok) {
          const cardEl = document.getElementById('card-' + CSS.escape(data.produto.codigo_produto));
          if (cardEl) {
            cardEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(function() { abrirModalQtd(cardEl.querySelector('.produto-card')); }, 400);
          }
        } else {
          showToast(data.msg, false);
        }
      })
      .catch(function() { showToast('Erro ao buscar produto.', false); });
    },
  });
})();
</script>
<% } %>
