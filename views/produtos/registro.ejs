<% title = 'Registro de Produtos'; activeMenu = '/produtos/registro'; %>

<div class="d-flex align-items-center gap-2 mb-3">
  <i class="bi bi-upc-scan text-primary fs-4"></i>
  <h5 class="mb-0 fw-bold">Registro de Produtos</h5>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-3">

    <!-- Seletor de cliente -->
    <div class="mb-3">
      <label class="form-label fw-semibold">Cliente</label>
      <select id="selCliente" class="form-select form-select-lg">
        <option value="">-- Selecione o cliente --</option>
        <% clientes.forEach(function(c) { %>
        <option value="<%= c.id_cliente %>"><%= c.nome %></option>
        <% }); %>
      </select>
    </div>

    <hr>

    <!-- Campo de codigo -->
    <div class="mb-3">
      <label class="form-label fw-semibold">Codigo EAN / DUN</label>
      <div class="input-group input-group-lg">
        <input type="text" id="inputCodigo" class="form-control font-monospace"
               placeholder="Digite ou leia o codigo..." autocomplete="off"
               inputmode="numeric" pattern="[0-9]*">
        <!-- Botao camera: visivel sempre, funciona em mobile -->
        <button class="btn btn-outline-primary" id="btnCamera" type="button" title="Abrir camera">
          <i class="bi bi-camera-fill"></i>
        </button>
      </div>
      <div class="form-text">Pressione Enter ou clique em Validar apos digitar.</div>
    </div>

    <!-- Reader da camera (oculto ate ativar) -->
    <div id="readerContainer" class="d-none mb-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="small text-muted">Aponte a camera para o codigo de barras</span>
        <button class="btn btn-sm btn-outline-danger" id="btnFecharCamera">
          <i class="bi bi-x-lg"></i> Fechar
        </button>
      </div>
      <div id="reader" class="rounded overflow-hidden"></div>
    </div>

    <!-- Quantidade (opcional) -->
    <div class="mb-3">
      <label class="form-label fw-semibold">Quantidade <span class="text-muted fw-normal">(opcional)</span></label>
      <input type="number" id="inputQtd" class="form-control form-control-lg"
             placeholder="0" min="0" step="0.001">
    </div>

    <button id="btnValidar" class="btn btn-primary btn-lg w-100" disabled>
      <i class="bi bi-check2-circle me-1"></i> Validar e Registrar
    </button>
  </div>
</div>

<!-- Resultado da validacao -->
<div id="resultado" class="mt-3 d-none">
  <div class="card border-0 shadow-sm">
    <div class="card-body p-3">
      <div class="d-flex align-items-center gap-3">
        <div class="flex-shrink-0">
          <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center"
               style="width:48px;height:48px;">
            <i class="bi bi-check-lg fs-4"></i>
          </div>
        </div>
        <div>
          <div class="fw-bold" id="resCodigo"></div>
          <div class="text-muted" id="resDescricao"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Toast de erro -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:11">
  <div id="toastErro" class="toast align-items-center text-white bg-danger border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body small" id="toastErroMsg"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="/js/scanner.js"></script>
<script>
(function() {
  const selCliente = document.getElementById('selCliente');
  const inputCodigo = document.getElementById('inputCodigo');
  const inputQtd    = document.getElementById('inputQtd');
  const btnValidar  = document.getElementById('btnValidar');
  const resultado   = document.getElementById('resultado');
  const toastErroEl = document.getElementById('toastErro');
  const toastErro   = new bootstrap.Toast(toastErroEl, { delay: 4000 });

  function showErro(msg) {
    document.getElementById('toastErroMsg').textContent = msg;
    toastErro.show();
  }

  selCliente.addEventListener('change', function() {
    btnValidar.disabled = !this.value || !inputCodigo.value.trim();
  });

  inputCodigo.addEventListener('input', function() {
    btnValidar.disabled = !selCliente.value || !this.value.trim();
    resultado.classList.add('d-none');
  });

  inputCodigo.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !btnValidar.disabled) btnValidar.click();
  });

  btnValidar.addEventListener('click', function() {
    const codigo    = inputCodigo.value.trim();
    const idCliente = selCliente.value;
    const qt        = inputQtd.value;

    btnValidar.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Validando...';
    btnValidar.disabled  = true;

    fetch('/api/produtos/validar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id_cliente: idCliente, codigo, qt_coletada: qt }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        document.getElementById('resCodigo').textContent    = codigo;
        document.getElementById('resDescricao').textContent = data.produto.descricao;
        resultado.classList.remove('d-none');
        inputCodigo.value = '';
        inputQtd.value    = '';
        inputCodigo.focus();
      } else {
        showErro(data.msg);
      }
    })
    .catch(function() { showErro('Erro de comunicacao.'); })
    .finally(function() {
      btnValidar.innerHTML = '<i class="bi bi-check2-circle me-1"></i> Validar e Registrar';
      btnValidar.disabled  = !selCliente.value || !inputCodigo.value.trim();
    });
  });

  // Camera
  initScanner({
    btnAbrir:    'btnCamera',
    btnFechar:   'btnFecharCamera',
    container:   'readerContainer',
    readerId:    'reader',
    onDecode: function(codigo) {
      inputCodigo.value = codigo;
      btnValidar.disabled = !selCliente.value;
      if (selCliente.value) btnValidar.click();
    },
  });
})();
</script>
