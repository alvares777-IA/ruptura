<%
  const qt = p.qt_coletada !== null && p.qt_coletada !== undefined
    ? parseFloat(p.qt_coletada).toLocaleString('pt-BR') : '—';
  const dtStr = p.dt_coleta
    ? (p.dt_coleta instanceof Date ? p.dt_coleta.toISOString().split('T')[0] : String(p.dt_coleta).split('T')[0])
    : '';
  const aoColetado = p.ao_coletado || 'N';
%>
<div class="col-12 col-md-6 col-lg-4" id="card-<%= p.codigo_produto %>">
  <div class="card border-0 shadow-sm produto-card h-100"
       data-codigo="<%= p.codigo_produto %>"
       data-descricao="<%= (p.descricao || '').replace(/"/g, '&quot;') %>"
       data-id-cliente="<%= p.id_cliente %>"
       data-dt-coleta="<%= dtStr %>"
       data-id-usuario="<%= p.id_usuario %>"
       data-qt="<%= p.qt_coletada !== null && p.qt_coletada !== undefined ? p.qt_coletada : '' %>"
       data-ao-coletado="<%= aoColetado %>"
       style="cursor:pointer<%= aoColetado === 'S' ? ';border-left:3px solid #198754' : '' %>">
    <div class="card-body py-2 px-3">
      <div class="d-flex align-items-center gap-2">
        <div class="flex-grow-1">
          <div class="fw-semibold font-monospace small"><%= p.codigo_produto %></div>
          <div class="text-muted small"><%= p.descricao || '—' %></div>
          <div class="mt-1 d-flex flex-wrap gap-1">
            <span class="badge bg-primary bg-opacity-10 text-primary">
              <i class="bi bi-layers me-1"></i>Qtd: <%= qt %>
            </span>
            <span class="badge bg-success bg-opacity-10 text-success badge-ao-coletado"
                  style="<%= aoColetado === 'S' ? '' : 'display:none' %>">
              <i class="bi bi-check-circle me-1"></i>Coletado
            </span>
            <% if (p.nome_usuario) { %>
            <span class="badge bg-light text-muted" style="font-size:.65rem"><%= p.nome_usuario %></span>
            <% } %>
          </div>
        </div>
        <button class="btn btn-outline-primary btn-sm p-2 btn-editar-qtd" title="Editar">
          <i class="bi bi-pencil-square fs-5"></i>
        </button>
      </div>
    </div>
  </div>
</div>
