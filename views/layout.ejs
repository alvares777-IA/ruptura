<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#0d6efd">
  <title><%- typeof title !== 'undefined' ? title + ' | Ruptura' : 'Ruptura' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/custom.css">
  <%- typeof style !== 'undefined' ? style : '' %>
</head>
<body class="bg-light">

<% if (user) { %>
<nav class="navbar navbar-dark bg-primary navbar-expand-md sticky-top shadow-sm">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="/dashboard">
      <i class="bi bi-box-seam me-1"></i> Ruptura
    </a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-label="Menu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav me-auto mb-2 mb-md-0">
        <%
          const grupos = {};
          const semGrupo = [];
          menus.forEach(function(m) {
            if (m.grupo) {
              if (!grupos[m.grupo]) grupos[m.grupo] = [];
              grupos[m.grupo].push(m);
            } else {
              semGrupo.push(m);
            }
          });
        %>
        <% semGrupo.forEach(function(m) { %>
        <li class="nav-item">
          <a class="nav-link<%= activeMenu === m.link ? ' active fw-semibold' : '' %>" href="<%= m.link %>">
            <i class="bi <%= m.icone %> me-1"></i><%= m.descricao %>
          </a>
        </li>
        <% }); %>
        <% Object.keys(grupos).forEach(function(grupo) { %>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" role="button">
            <i class="bi bi-grid me-1"></i><%= grupo %>
          </a>
          <ul class="dropdown-menu dropdown-menu-dark">
            <% grupos[grupo].forEach(function(m) { %>
            <li>
              <a class="dropdown-item<%= activeMenu === m.link ? ' active' : '' %>" href="<%= m.link %>">
                <i class="bi <%= m.icone %> me-2"></i><%= m.descricao %>
              </a>
            </li>
            <% }); %>
          </ul>
        </li>
        <% }); %>
      </ul>
      <ul class="navbar-nav ms-auto">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" role="button">
            <i class="bi bi-person-circle me-1"></i>
            <span class="d-none d-md-inline"><%= user.nome.split(' ')[0] %></span>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><span class="dropdown-item-text text-muted small"><%= user.email %></span></li>
            <% if (user.admin) { %>
            <li><span class="dropdown-item-text"><span class="badge bg-danger">Admin</span></span></li>
            <% } %>
            <li><hr class="dropdown-divider"></li>
            <li>
              <a class="dropdown-item text-danger" href="/logout">
                <i class="bi bi-box-arrow-right me-2"></i>Sair
              </a>
            </li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>
<% } %>

<% if (flash) { %>
<div class="container-fluid mt-2 px-3">
  <div class="alert alert-<%= flash.tipo %> alert-dismissible fade show mb-0 py-2 small" role="alert">
    <i class="bi <%= flash.tipo === 'success' ? 'bi-check-circle' : 'bi-exclamation-circle' %> me-1"></i>
    <%= flash.msg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
</div>
<% } %>

<main class="<%= user ? 'container-fluid py-3 px-3 px-md-4' : '' %>">
  <%- body %>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="/js/main.js"></script>
<%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
