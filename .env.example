# =============================================
# Ruptura — Variaveis de Ambiente
# Copie este arquivo para .env e preencha
# =============================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Banco de dados PostgreSQL (app) ---
# Formato: postgres://usuario:senha@host:porta/banco
DATABASE_URL=postgres://ruptura:senha@localhost:5432/ruptura

# --- Sessao ---
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=troque_por_uma_string_aleatoria_longa

# --- Google OAuth2 (opcional) ---
# Crie em: https://console.cloud.google.com/apis/credentials
# URI de redirecionamento autorizado: https://seudominio.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- Email (SMTP) ---
# Usado para notificar admins quando um novo usuario se cadastra
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ruptura.local

# --- Admin padrao (usado apenas no seed) ---
ADMIN_EMAIL=admin@ruptura.local
ADMIN_SENHA=Admin@2024
